insert into reference.manufacturer_item_types (
  manufacturer_id,
  item_type_id,
  confidence,
  relationship_source
)
select
  m.manufacturer_id,
  it.item_type_id,
  r.confidence,
  'curated_seed'
from relationships r
join reference.manufacturers m
  on m.manufacturer_code = r.manufacturer_code
join reference.item_types it
  on it.item_type_code = r.item_type_code
on conflict (manufacturer_id, item_type_id)
do update set
  confidence = excluded.confidence,
  relationship_source = excluded.relationship_source,
  is_active = true;


commit;
