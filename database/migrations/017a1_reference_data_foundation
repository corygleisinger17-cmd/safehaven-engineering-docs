begin;

-- ============================================================
-- SAFEHAVEN MIGRATION 017A1
-- Reference Data Foundation
-- ============================================================
--
-- Creates SafeHaven-owned reference data separately from
-- household and user-owned data.
--
-- Tables:
--   reference.categories
--   reference.item_types
--   reference.manufacturers
--   reference.manufacturer_item_types
--
-- Authenticated users receive read-only access.
-- Writes remain restricted to trusted backend/database roles.
-- ============================================================


-- ============================================================
-- 1. REFERENCE SCHEMA
-- ============================================================

create schema if not exists reference;

comment on schema reference is
  'SafeHaven-owned reference knowledge and standardized lookup data.';


-- ============================================================
-- 2. CATEGORIES
-- ============================================================

create table if not exists reference.categories (
  category_id uuid primary key default gen_random_uuid(),

  category_code text not null,
  category_name text not null,

  description text,
  display_order integer not null default 100,
  icon_name text,

  is_active boolean not null default true,

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  constraint categories_code_format_check
    check (
      category_code = upper(category_code)
      and category_code ~ '^[A-Z][A-Z0-9_]*$'
    ),

  constraint categories_name_not_blank_check
    check (nullif(btrim(category_name), '') is not null),

  constraint categories_display_order_check
    check (display_order >= 0),

  constraint categories_code_unique
    unique (category_code),

  constraint categories_name_unique
    unique (category_name)
);

comment on table reference.categories is
  'Standardized top-level household inventory categories.';

comment on column reference.categories.category_code is
  'Stable machine-readable identifier used by APIs, imports, and AI systems.';


-- ============================================================
-- 3. ITEM TYPES
-- ============================================================

create table if not exists reference.item_types (
  item_type_id uuid primary key default gen_random_uuid(),

  category_id uuid not null
    references reference.categories(category_id)
    on update cascade
    on delete restrict,

  item_type_code text not null,
  item_type_name text not null,
  display_name text not null,

  description text,

  maintenance_required boolean not null default false,
  critical_item boolean not null default false,
  energy_consuming boolean not null default false,

  expected_lifespan_years numeric(5,2),
  default_warranty_months integer,
  default_maintenance_interval_days integer,

  insurance_category text,

  display_order integer not null default 100,
  is_active boolean not null default true,

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  constraint item_types_code_format_check
    check (
      item_type_code = upper(item_type_code)
      and item_type_code ~ '^[A-Z][A-Z0-9_]*$'
    ),

  constraint item_types_name_not_blank_check
    check (nullif(btrim(item_type_name), '') is not null),

  constraint item_types_display_name_not_blank_check
    check (nullif(btrim(display_name), '') is not null),

  constraint item_types_lifespan_check
    check (
      expected_lifespan_years is null
      or expected_lifespan_years > 0
    ),

  constraint item_types_warranty_check
    check (
      default_warranty_months is null
      or default_warranty_months >= 0
    ),

  constraint item_types_maintenance_interval_check
    check (
      default_maintenance_interval_days is null
      or default_maintenance_interval_days > 0
    ),

  constraint item_types_display_order_check
    check (display_order >= 0),

  constraint item_types_code_unique
    unique (item_type_code),

  constraint item_types_category_name_unique
    unique (category_id, item_type_name)
);

comment on table reference.item_types is
  'Standardized item types understood by the SafeHaven knowledge engine.';

comment on column reference.item_types.expected_lifespan_years is
  'General default lifespan used until a more precise profile or manufacturer override is available.';

comment on column reference.item_types.default_maintenance_interval_days is
  'General recurring maintenance interval, when applicable.';


-- ============================================================
-- 4. MANUFACTURERS
-- ============================================================

create table if not exists reference.manufacturers (
  manufacturer_id uuid primary key default gen_random_uuid(),

  manufacturer_code text not null,
  manufacturer_name text not null,

  website_url text,
  support_url text,
  country_code text,
  logo_url text,

  is_active boolean not null default true,

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  constraint manufacturers_code_format_check
    check (
      manufacturer_code = upper(manufacturer_code)
      and manufacturer_code ~ '^[A-Z][A-Z0-9_]*$'
    ),

  constraint manufacturers_name_not_blank_check
    check (nullif(btrim(manufacturer_name), '') is not null),

  constraint manufacturers_country_code_check
    check (
      country_code is null
      or country_code ~ '^[A-Z]{2}$'
    ),

  constraint manufacturers_code_unique
    unique (manufacturer_code),

  constraint manufacturers_name_unique
    unique (manufacturer_name)
);

comment on table reference.manufacturers is
  'Standardized manufacturers and brands recognized by SafeHaven.';


-- ============================================================
-- 5. MANUFACTURER ↔ ITEM TYPE RELATIONSHIPS
-- ============================================================

create table if not exists reference.manufacturer_item_types (
  manufacturer_item_type_id uuid primary key
    default gen_random_uuid(),

  manufacturer_id uuid not null
    references reference.manufacturers(manufacturer_id)
    on update cascade
    on delete cascade,

  item_type_id uuid not null
    references reference.item_types(item_type_id)
    on update cascade
    on delete cascade,

  confidence smallint not null default 100,

  relationship_source text not null default 'curated',
  notes text,

  is_active boolean not null default true,

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  constraint manufacturer_item_types_confidence_check
    check (confidence between 0 and 100),

  constraint manufacturer_item_types_source_not_blank_check
    check (
      nullif(btrim(relationship_source), '') is not null
    ),

  constraint manufacturer_item_types_unique
    unique (manufacturer_id, item_type_id)
);

comment on table reference.manufacturer_item_types is
  'Known relationships between manufacturers and the item types they produce.';

comment on column reference.manufacturer_item_types.confidence is
  'Confidence from 0–100 that the manufacturer commonly produces the item type.';


-- ============================================================
-- 6. UPDATED_AT TRIGGERS
-- ============================================================

drop trigger if exists set_categories_updated_at
  on reference.categories;

create trigger set_categories_updated_at
before update on reference.categories
for each row
execute function public.set_updated_at();


drop trigger if exists set_item_types_updated_at
  on reference.item_types;

create trigger set_item_types_updated_at
before update on reference.item_types
for each row
execute function public.set_updated_at();


drop trigger if exists set_manufacturers_updated_at
  on reference.manufacturers;

create trigger set_manufacturers_updated_at
before update on reference.manufacturers
for each row
execute function public.set_updated_at();


drop trigger if exists set_manufacturer_item_types_updated_at
  on reference.manufacturer_item_types;

create trigger set_manufacturer_item_types_updated_at
before update on reference.manufacturer_item_types
for each row
execute function public.set_updated_at();


-- ============================================================
-- 7. INDEXES
-- ============================================================

create index if not exists idx_reference_categories_active_order
  on reference.categories (
    is_active,
    display_order,
    category_name
  );

create index if not exists idx_reference_item_types_category
  on reference.item_types (
    category_id,
    is_active,
    display_order,
    item_type_name
  );

create index if not exists idx_reference_item_types_name_lower
  on reference.item_types (
    lower(item_type_name)
  );

create index if not exists idx_reference_item_types_display_lower
  on reference.item_types (
    lower(display_name)
  );

create index if not exists idx_reference_manufacturers_name_lower
  on reference.manufacturers (
    lower(manufacturer_name)
  );

create index if not exists idx_reference_manufacturers_active
  on reference.manufacturers (
    is_active,
    manufacturer_name
  );

create index if not exists idx_reference_manufacturer_item_types_type
  on reference.manufacturer_item_types (
    item_type_id,
    confidence desc
  );

create index if not exists idx_reference_manufacturer_item_types_manufacturer
  on reference.manufacturer_item_types (
    manufacturer_id,
    confidence desc
  );


-- ============================================================
-- 8. READ-ONLY ACCESS
-- ============================================================

revoke all on schema reference from public;
revoke all on all tables in schema reference from public;

grant usage on schema reference to authenticated;

grant select on reference.categories
  to authenticated;

grant select on reference.item_types
  to authenticated;

grant select on reference.manufacturers
  to authenticated;

grant select on reference.manufacturer_item_types
  to authenticated;


